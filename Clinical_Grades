    const clinicalScale = {};
    clinicalScaleText.trim().split("\n").forEach(line => {
      const parts = line.trim().split(/\s+/);
      clinicalScale[parts[0]] = Number(parts[1]);
    });

    function togglePresentationField() {
      const hasPresentation = document.getElementById("hasPresentation").value;
      document.getElementById("presentationField").style.display = hasPresentation === "yes" ? "block" : "none";
    }

    function getLetterGrade(percent) {
      if (percent >= 92) return "A";
      if (percent >= 84) return "B";
      if (percent >= 75) return "C";
      if (percent >= 67) return "D";
      return "F";
    }

    function showError(message) {
      const error = document.getElementById("error");
      error.textContent = message;
      error.style.display = "block";
      document.getElementById("result").style.display = "none";
    }

    function calculateGrade() {
      const hasPresentation = document.getElementById("hasPresentation").value === "yes";
      const clinicalInput = Number(document.getElementById("clinicalScore").value);
      const dailyLogScore = Number(document.getElementById("dailyLogScore").value);
      const presentationScore = Number(document.getElementById("presentationScore").value);

      if (isNaN(clinicalInput) || clinicalInput < 0 || clinicalInput > 3) {
        showError("Please enter a Clinical Evaluation score from 0.00 to 3.00.");
        return;
      }

      if (isNaN(dailyLogScore) || dailyLogScore < 0 || dailyLogScore > 100) {
        showError("Please enter a Daily Log Sheets percentage from 0 to 100.");
        return;
      }

      if (hasPresentation && (isNaN(presentationScore) || presentationScore < 0 || presentationScore > 100)) {
        showError("Please enter a Site Visit Presentation percentage from 0 to 100.");
        return;
      }

      const clinicalKey = clinicalInput.toFixed(2);
      const clinicalPercent = clinicalScale[clinicalKey];

      if (clinicalPercent === undefined) {
        showError("Clinical Evaluation score must be entered to two decimal places between 0.00 and 3.00.");
        return;
      }

      let finalPercent;
      let formulaText;

      if (hasPresentation) {
        finalPercent = (clinicalPercent * 0.75) + (dailyLogScore * 0.15) + (presentationScore * 0.10);
        formulaText = "Clinical Evaluation 75%, Daily Log Sheets 15%, Site Visit Presentation 10%";
      } else {
        finalPercent = (clinicalPercent * 0.75) + (dailyLogScore * 0.25);
        formulaText = "Clinical Evaluation 75%, Daily Log Sheets 25%";
      }

      const letterGrade = getLetterGrade(finalPercent);

      document.getElementById("error").style.display = "none";
      const result = document.getElementById("result");
      result.innerHTML = `
        <strong>Final Percentage:</strong> ${finalPercent.toFixed(2)}%<br>
        <strong>Final Letter Grade:</strong> ${letterGrade}<br><br>
        <strong>Clinical Evaluation Converted Percentage:</strong> ${clinicalPercent.toFixed(2)}%<br>
        <strong>Grade Distribution Used:</strong> ${formulaText}
      `;
      result.style.display = "block";
    }

    togglePresentationField();
  </script>
