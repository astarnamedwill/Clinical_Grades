<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Clinical Grade Calculator</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 760px;
      margin: 30px auto;
      padding: 20px;
      line-height: 1.5;
      color: #222;
    }
    h1 { text-align: center; }
    .box {
      border: 1px solid #ccc;
      border-radius: 10px;
      padding: 20px;
      background: #f9f9f9;
      margin-bottom: 20px;
    }
    label {
      display: block;
      font-weight: bold;
      margin-top: 15px;
    }
    input, select {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      font-size: 1rem;
      box-sizing: border-box;
    }
    button {
      margin-top: 20px;
      width: 100%;
      padding: 12px;
      font-size: 1rem;
      font-weight: bold;
      cursor: pointer;
      border: none;
      border-radius: 8px;
      background: #005a9c;
      color: white;
    }
    button:hover { background: #00457a; }
    .result {
      display: none;
      border-radius: 10px;
      padding: 20px;
      background: #eef7ee;
      border: 1px solid #8fc58f;
      font-size: 1.1rem;
    }
    .error {
      display: none;
      border-radius: 10px;
      padding: 15px;
      background: #ffecec;
      border: 1px solid #d88;
      color: #900;
      margin-top: 15px;
    }
    .note {
      font-size: 0.92rem;
      color: #555;
    }
  </style>
</head>
<body>
  <h1>Clinical Grade Calculator</h1>

  <div class="box">
    <label for="hasPresentation">Do you have a Site Visit Presentation this semester?</label>
    <select id="hasPresentation" onchange="togglePresentationField()">
      <option value="yes">Yes</option>
      <option value="no">No</option>
    </select>

    <label for="clinicalScore">Clinical Evaluation Score, 0.00 to 3.00</label>
    <input id="clinicalScore" type="number" min="0" max="3" step="0.01" placeholder="Example: 2.85" />
    <div class="note">Enter the score as a number from 0.00 to 3.00.</div>

    <label for="dailyLogScore">Daily Log Sheets Percentage</label>
    <input id="dailyLogScore" type="number" min="0" max="100" step="0.01" placeholder="Example: 95" />

    <div id="presentationField">
      <label for="presentationScore">Site Visit Presentation Percentage</label>
      <input id="presentationScore" type="number" min="0" max="100" step="0.01" placeholder="Example: 90" />
    </div>

    <button onclick="calculateGrade()">Calculate Grade</button>
    <div id="error" class="error"></div>
  </div>

  <div id="result" class="result"></div>

